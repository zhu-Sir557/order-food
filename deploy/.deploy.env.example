# ============================================================
#  部署配置文件 - 请复制此文件为 .deploy.env 并填写真实信息
#  .deploy.env 会被 .gitignore 排除，不会上传到 GitHub
# ============================================================

# 服务器连接
DEPLOY_SERVER_HOST=你的服务器IP
DEPLOY_SERVER_USER=root
DEPLOY_SERVER_PASS=你的服务器密码

# 阿里云 OSS
OSS_ENDPOINT=https://oss-cn-shanghai.aliyuncs.com
OSS_ACCESS_KEY_ID=你的AccessKey ID
OSS_ACCESS_KEY_SECRET=你的AccessKey Secret
OSS_BUCKET_NAME=你的bucket名称
