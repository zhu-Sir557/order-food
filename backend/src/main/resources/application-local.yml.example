# =====================================================
# 本地开发环境配置模板
# 使用方法：复制此文件为 application-local.yml，填入真实密码
#   cp application-local.yml.example application-local.yml
#
# application-local.yml 不会提交到 Git（已在 .gitignore 中排除）
# Spring Boot 启动时会自动加载 local profile，覆盖 dev 中的密码
# =====================================================

spring:
  datasource:
    password: <your-mysql-password>

jwt:
  secret: <your-jwt-secret-key>

aliyun:
  oss:
    access-key-id: <your-oss-access-key-id>
    access-key-secret: <your-oss-access-key-secret>
  # 短信验证码登录（Dypnsapi）：AK/SK 复用 OSS 同款 RAM 凭证
  dypnsapi:
    access-key-id: <your-dypnsapi-access-key-id>
    access-key-secret: <your-dypnsapi-access-key-secret>

# 以下为账号增强相关默认值（与 application-dev.yml 保持一致，本地可覆盖）
# login:
#   defense:
#     login-fail-max: 5
#     login-lock-minutes: 15
# password:
#   min-length: 8
# profile:
#   nick-daily-limit: 3
#   avatar-daily-limit: 5
# avatar:
#   count: 12
#   init:
#     enabled: true
