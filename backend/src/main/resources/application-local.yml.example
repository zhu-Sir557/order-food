# =====================================================
# 本地开发环境配置模板
# 使用方法：复制此文件为 application-local.yml，填入真实密码
#   cp application-local.yml.example application-local.yml
#
# application-local.yml 不会提交到 Git（已在 .gitignore 中排除）
# Spring Boot 启动时会自动加载 local profile，覆盖 dev 中的密码
# =====================================================

spring:
  datasource:
    password: <your-mysql-password>

jwt:
  secret: <your-jwt-secret-key>

aliyun:
  oss:
    access-key-id: <your-oss-access-key-id>
    access-key-secret: <your-oss-access-key-secret>
