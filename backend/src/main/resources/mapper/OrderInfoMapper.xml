<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.restaurant.mapper.OrderInfoMapper">

    <!-- Result map for order detail with items -->
    <resultMap id="orderDetailMap" type="java.util.Map">
        <id property="id" column="o_id"/>
        <result property="orderNo" column="order_no"/>
        <result property="tempUserId" column="temp_user_id"/>
        <result property="tableId" column="table_id"/>
        <result property="tableCode" column="table_code"/>
        <result property="totalAmount" column="total_amount"/>
        <result property="status" column="status"/>
        <result property="remark" column="remark"/>
        <result property="createTime" column="create_time"/>
        <result property="updateTime" column="update_time"/>
        <collection property="items" ofType="java.util.Map" javaType="java.util.List">
            <id property="id" column="oi_id"/>
            <result property="dishId" column="dish_id"/>
            <result property="dishName" column="dish_name"/>
            <result property="dishPrice" column="dish_price"/>
            <result property="dishImage" column="dish_image"/>
            <result property="quantity" column="quantity"/>
            <result property="subtotal" column="subtotal"/>
            <result property="tasteSelection" column="taste_selection"/>
        </collection>
    </resultMap>

    <!-- Query order detail by order ID, including all order items -->
    <select id="selectOrderDetailById" resultMap="orderDetailMap">
        SELECT
            o.id          AS o_id,
            o.order_no,
            o.temp_user_id,
            o.table_id,
            o.table_code,
            o.total_amount,
            o.status,
            o.remark,
            o.create_time,
            o.update_time,
            oi.id         AS oi_id,
            oi.dish_id,
            oi.dish_name,
            oi.dish_price,
            oi.dish_image,
            oi.quantity,
            oi.subtotal,
            oi.taste_selection
        FROM order_info o
        LEFT JOIN order_item oi ON o.id = oi.order_id
        WHERE o.id = #{orderId}
          AND o.deleted = 0
        ORDER BY oi.id
    </select>

    <!-- Query orders by temporary user ID with their items -->
    <resultMap id="orderListMap" type="java.util.Map">
        <id property="id" column="o_id"/>
        <result property="orderNo" column="order_no"/>
        <result property="tempUserId" column="temp_user_id"/>
        <result property="tableId" column="table_id"/>
        <result property="tableCode" column="table_code"/>
        <result property="totalAmount" column="total_amount"/>
        <result property="status" column="status"/>
        <result property="remark" column="remark"/>
        <result property="createTime" column="create_time"/>
        <result property="updateTime" column="update_time"/>
        <collection property="items" ofType="java.util.Map" javaType="java.util.List">
            <id property="id" column="oi_id"/>
            <result property="dishId" column="dish_id"/>
            <result property="dishName" column="dish_name"/>
            <result property="dishPrice" column="dish_price"/>
            <result property="dishImage" column="dish_image"/>
            <result property="quantity" column="quantity"/>
            <result property="subtotal" column="subtotal"/>
            <result property="tasteSelection" column="taste_selection"/>
        </collection>
    </resultMap>

    <select id="selectOrdersByTempUserId" resultMap="orderListMap">
        SELECT
            o.id          AS o_id,
            o.order_no,
            o.temp_user_id,
            o.table_id,
            o.table_code,
            o.total_amount,
            o.status,
            o.remark,
            o.create_time,
            o.update_time,
            oi.id         AS oi_id,
            oi.dish_id,
            oi.dish_name,
            oi.dish_price,
            oi.dish_image,
            oi.quantity,
            oi.subtotal,
            oi.taste_selection
        FROM order_info o
        LEFT JOIN order_item oi ON o.id = oi.order_id
        WHERE o.temp_user_id = #{tempUserId}
          AND o.deleted = 0
        ORDER BY o.create_time DESC, oi.id
    </select>

</mapper>
