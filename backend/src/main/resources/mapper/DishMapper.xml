<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.restaurant.mapper.DishMapper">

    <!-- Result map for dish with category name -->
    <resultMap id="dishWithCategoryMap" type="java.util.Map">
        <id property="id" column="id"/>
        <result property="categoryId" column="category_id"/>
        <result property="name" column="name"/>
        <result property="price" column="price"/>
        <result property="image" column="image"/>
        <result property="description" column="description"/>
        <result property="tasteConfig" column="taste_config"/>
        <result property="stock" column="stock"/>
        <result property="status" column="status"/>
        <result property="createTime" column="create_time"/>
        <result property="updateTime" column="update_time"/>
        <result property="categoryName" column="category_name"/>
    </resultMap>

    <!-- Paginated query of dishes with category name -->
    <select id="selectDishPage" resultMap="dishWithCategoryMap">
        SELECT
            d.id,
            d.category_id,
            d.name,
            d.price,
            d.image,
            d.description,
            d.taste_config,
            d.stock,
            d.status,
            d.create_time,
            d.update_time,
            c.name AS category_name
        FROM dish d
        LEFT JOIN category c ON d.category_id = c.id AND c.deleted = 0
        WHERE d.deleted = 0
        <if test="categoryId != null">
            AND d.category_id = #{categoryId}
        </if>
        <if test="name != null and name != ''">
            AND d.name LIKE CONCAT('%', #{name}, '%')
        </if>
        <if test="status != null">
            AND d.status = #{status}
        </if>
        ORDER BY d.create_time DESC
    </select>

</mapper>
